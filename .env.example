# ══════════════════════════════════════════════════════════════════════════════
# LangChain: Zero to Hero — with DeepAgents
# Master .env.example — copy to .env and fill in your values
# NEVER commit a .env file containing real keys to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── LLM PROVIDERS ─────────────────────────────────────────────────────────────
# Primary provider used throughout the curriculum.
# Required for all Level 1 examples and as the default in all projects.
OPENAI_API_KEY=sk-...

# Model name override. Defaults to gpt-4o-mini if not set.
OPENAI_MODEL=gpt-4o-mini

# Set to 0 for deterministic agent outputs; raise for creative tasks.
OPENAI_TEMPERATURE=0

# Anthropic — required for multi-model comparison projects (B-2 Prompt Lab).
ANTHROPIC_API_KEY=sk-ant-...

# Anthropic model override. Defaults to claude-3-haiku-20240307.
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Google Gemini — optional, used in multi-model comparison only.
GOOGLE_API_KEY=AIza...

# Google model override. Defaults to gemini-1.5-flash.
GOOGLE_MODEL=gemini-1.5-flash

# Active provider for shared/utils/model_factory.py.
# One of: openai | anthropic | google
MODEL_PROVIDER=openai

# ── LANGSMITH OBSERVABILITY ───────────────────────────────────────────────────
# Required for all Level 2+ projects (RAG, agents, multi-actor workflows).
# Get your key at: https://smith.langchain.com
LANGSMITH_API_KEY=lsv2_...

# Set to "true" to enable tracing; "false" to disable without code changes.
LANGSMITH_TRACING=true

# Optional: override the LangSmith endpoint for self-hosted deployments.
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ── SEARCH & RETRIEVAL ────────────────────────────────────────────────────────
# Tavily is the recommended web search provider for all Level 3 agent projects.
# Required for: A-1 Research Assistant, A-2 Travel Planner, A-6 Sales Intelligence.
# Get your key at: https://tavily.com
TAVILY_API_KEY=tvly-...

# ── VECTOR STORES ─────────────────────────────────────────────────────────────
# Pinecone — used as an optional cloud vector store alternative to Chroma/FAISS.
# Projects default to local Chroma if PINECONE_API_KEY is not set.
PINECONE_API_KEY=pcsk_...
PINECONE_ENVIRONMENT=us-east-1

# ── EXTERNAL APIS (project-specific) ─────────────────────────────────────────
# OpenWeatherMap — used in A-2 Multi-Tool Travel Planner for weather data.
OPENWEATHERMAP_API_KEY=...

# ── LOGGING ───────────────────────────────────────────────────────────────────
# Controls log verbosity across all projects.
# One of: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
